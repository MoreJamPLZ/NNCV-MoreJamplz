# --- Environment & Secrets ---
# Never commit sensitive credentials or environment-specific settings
.env
.env.local
.env.*.local

# --- Data & Large Files ---
# Ignore raw data, processed datasets, and archives
data/
*.zip
*.tar.gz

# --- Build Artifacts & Logs ---
# Compiled output and Singularity images
*.out
*.sif
*.log

# --- System & IDE Files ---
# Common files generated by OS or editors
.DS_Store
Thumbs.db
.vscode/
.idea/
